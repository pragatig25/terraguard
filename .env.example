# TerraGuard environment — copy to .env for local runs. NEVER commit .env.
# Claude API key for AI triage + remediation (Haiku 4.5).
ANTHROPIC_API_KEY=

# GitHub token for auto-fix PR creation + metrics publishing (local only;
# in Actions this is provided automatically as GITHUB_TOKEN).
GITHUB_TOKEN=

# owner/repo used by autopr + metrics publisher.
TERRAGUARD_REPO=pragatig25/terraguard

# Optional: model override (defaults to claude-haiku-4-5).
TERRAGUARD_MODEL=claude-haiku-4-5

# Runtime paths (set automatically by the workflow; override for local runs).
TERRAGUARD_BASELINE=/tmp/baseline.json
TERRAGUARD_OUTPUT=/tmp/terraguard_results.json
TERRAGUARD_CURRENT_RESULTS=/tmp/terraguard_results.json
